# XFinder Environment Configuration
# Copy this file to ".env" and adjust values to your environment.

# ----- PostgreSQL Credentials -----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=xfinder
DB_USER=xfinder
DB_PASSWORD=useyourpassword

# ----- External API Keys -----
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=

# ----- Scan Performance -----
DEFAULT_THREADS=20
HTTPX_TIMEOUT=15
DNSX_TIMEOUT=10
NAABU_TIMEOUT=15
NMAP_TIMEOUT=60
KATANA_TIMEOUT=120
NUCLEI_TIMEOUT=180
SCAN_RATE=1000

# ----- Scheduling -----
SCAN_INTERVAL_MINUTES=60

# ----- Output -----
OUTPUT_DIR=./output

# ----- Logging -----
LOG_LEVEL=INFO
LOG_DIR=./logs

# ----- Nuclei Templates -----
NUCLEI_SEVERITY=low,medium,high,critical
